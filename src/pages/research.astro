---
import {
  Building2,
  Compass,
  GraduationCap,
  Landmark,
  Leaf,
  Network,
  PawPrint,
  RadioTower,
  Scale,
  ShieldCheck,
} from "@lucide/astro";
import Hero from "../components/Hero.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import Layout from "../layouts/Layout.astro";
import { assets, currentProjects, researchAreas, researchThemes } from "../data/site";

const themeIcons = [Scale, GraduationCap, PawPrint, Landmark, ShieldCheck];
const areaIcons = [Building2, Landmark, Leaf, RadioTower, Network, Compass];
---

<Layout title="Research | CASS Lab" description="Research themes, areas, and current projects at CASS Lab.">
  <SiteHeader activePath="/research/" />
  <Hero title="Research" image={assets.researchHero} />
  <main id="content">
    <section class="page-section page-section" aria-labelledby="themes-heading">
      <div class="section-shell">
        <div class="section-heading section-heading--center">
          <h2 id="themes-heading">Thematic Focuses</h2>
          <p>A structural overview of our intersecting domains of inquiry.</p>
        </div>
        <div class="research-map" aria-label="CASS Lab research themes">
          {researchThemes.map((theme, index) => {
            const Icon = themeIcons[index];
            return (
            <article class={`theme-card theme-card--${index + 1}`}>
              <Icon class="theme-card__icon" aria-hidden="true" size={24} strokeWidth={1.8} />
              <h3>{theme.title}</h3>
              <p class="small-label">Keywords</p>
              <p>{theme.keywords}</p>
            </article>
            );
          })}
          <article class="theme-card theme-card--core">
            <img src="/hub.svg" alt="" class="theme-card__hub" aria-hidden="true" />
            <h3>Chinese &amp; Asian Science and Technology</h3>
            <p class="small-label">Core Research Hub</p>
          </article>
        </div>
      </div>
    </section>

    <!-- <section class="page-section" aria-labelledby="areas-heading">
      <div class="section-shell">
        <div class="section-heading">
          <h2 id="areas-heading">Areas of Research</h2>
        </div>
        <div class="card-grid card-grid--three">
          {researchAreas.map((area, index) => {
            const Icon = areaIcons[index];
            return (
            <article class="info-card research-card">
              <span class="card-icon" aria-hidden="true"><Icon size={18} strokeWidth={1.8} /></span>
              <h3>{area.title}</h3>
              <p>{area.description}</p>
            </article>
            );
          })}
        </div>
      </div>
    </section> -->

    <section class="page-section page-section--warm" aria-labelledby="projects-heading">
      <div class="section-shell">
        <div class="section-heading section-heading--row">
          <h2 id="projects-heading">Current Projects</h2>
          <p class="small-label">Active Grants</p>
        </div>
        <div class="project-list">
          {currentProjects.map((project) => (
            <article class="project-card">
              <aside class="project-card__meta">
                <p class="small-label">Funding Agency</p>
                <p>{project.fundingAgency}</p>
                <p class="small-label">Duration</p>
                <p>{project.duration}</p>
              </aside>
              <div class="project-card__body">
                <h3>{project.title}</h3>
                <p>{project.description}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</Layout>
