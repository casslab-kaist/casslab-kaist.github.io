---
import { Building2, UserRound } from "@lucide/astro";

interface Props {
  name: string;
  role?: string;
  affiliation?: string;
  degree?: string;
  current?: string;
  withPortraitPlaceholder?: boolean;
}

const { name, role, affiliation, degree, current, withPortraitPlaceholder = false } = Astro.props;
---

<article class:list={["person-card", withPortraitPlaceholder && "person-card--portrait"]}>
  {
    withPortraitPlaceholder && (
      <div class="person-card__photo" aria-hidden="true">
        <UserRound size={32} strokeWidth={1.7} />
      </div>
    )
  }
  <div class="person-card__body">
    <h3>{name}</h3>
    {(role || affiliation) && (
      <div class="person-card__meta">
        {role && <p class="person-card__role">{role}</p>}
        {
          affiliation && (
            <p class="person-card__affiliation">
              <Building2 aria-hidden="true" size={15} strokeWidth={1.9} />
              <span>{affiliation}</span>
            </p>
          )
        }
      </div>
    )}
    {degree && <p class="person-card__degree">{degree}</p>}
    {current && <p class="person-card__current">Current: {current}</p>}
  </div>
</article>
