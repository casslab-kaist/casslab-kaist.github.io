---
import type { PublicationSection } from "../data/publications";

interface Props {
  sections: PublicationSection[];
}

const { sections } = Astro.props;
---

<aside class="category-panel" aria-labelledby="category-heading">
  <h2 id="category-heading">Categories</h2>
  <nav aria-label="Publication categories">
    {sections.map((section, index) => (
      <a class:list={["category-link", index === 0 && "is-active"]} data-category-link={section.id} href={`#${section.id}`}>
        {section.navLabel}
      </a>
    ))}
  </nav>
</aside>
